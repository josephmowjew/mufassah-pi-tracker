# =============================================================================
# MUFASSAH DEVICE TRACKER CONFIGURATION
# =============================================================================
# Edit this file with your API credentials and settings

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Your backend API base URL (include /api/v1/iot)
API_BASE_URL=https://your-domain.com/api/v1/iot

# Module ID (from backend - e.g., MUF-001)
MODULE_ID=MUF-001

# API Token (64-character token from backend)
API_TOKEN=your_64_char_api_token_from_backend

# -----------------------------------------------------------------------------
# Tracking Configuration
# -----------------------------------------------------------------------------
# How often to send location updates (in seconds)
# 300 = 5 minutes (recommended for normal operation)
# 30 = 30 seconds (for stolen mode - can be changed dynamically)
TRACKING_INTERVAL=300

# How often to send heartbeat (in seconds)
HEARTBEAT_INTERVAL=60

# Maximum number of locations to buffer when offline
BUFFER_MAX_SIZE=1000

# -----------------------------------------------------------------------------
# GPS Configuration
# -----------------------------------------------------------------------------
# Maximum GPS accuracy to accept (in meters)
# Locations with accuracy worse than this will be rejected
MAX_GPS_ACCURACY=50

# gpsd host (usually localhost)
GPSD_HOST=localhost

# gpsd port (usually 2947)
GPSD_PORT=2947

# -----------------------------------------------------------------------------
# API Retry Configuration
# -----------------------------------------------------------------------------
# Number of times to retry failed API calls before buffering
API_RETRY_COUNT=3

# Delay between API retries (in seconds)
API_RETRY_DELAY=5
